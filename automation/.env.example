# Supabase (Obrigatório)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Evolution API (Obrigatório)
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=your-evolution-api-key-here

# Worker Configuration (Opcional)
WORKER_POLL_INTERVAL_MS=5000
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_LOCK_TIMEOUT_MINUTES=5
WORKER_MAX_ATTEMPTS=3
WORKER_NAME=automation-worker

# Dry Run Mode (Opcional)
DRY_RUN=false

# Teste controlado sem humanização (Opcional)
BYPASS_HUMANIZER_TEST_PHONE=
BYPASS_HUMANIZER_TEST_TAG=
